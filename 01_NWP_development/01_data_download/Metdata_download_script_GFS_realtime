#!/bin/bash

# Set the start date and time for the forecast
start_date=$(date +%Y%m%d)
start_time="00"

# Set the number of forecast hours (1 day = 24 hours)
forecast_hours=12

# Set the forecast interval in hours
forecast_interval=6

# Set the number of parallel downloads (equal to the number of files)
num_parallel_downloads=8

# Set the output directory
output_dir="/Users/haseeb.rehman/Documents/gis4wrf/datasets/met/GFS/$start_date"

# Create the output directory if it doesn't exist
mkdir -p "$output_dir"

# Function to compare file size for resuming interrupted downloads
compare_file_size() {
    local file_path=$1
    local url=$2

    # Check if the file already exists
    if [ -e "$file_path" ]; then
        local local_size=$(stat -c %s "$file_path")
        local remote_size=$(curl --head -s "$url" | awk '/Content-Length/{print $2}' | tr -d '\r')
        
        # Compare local and remote file sizes
        if [ "$local_size" != "$remote_size" ]; then
            echo "Resuming download for $file_path"
            curl -C - -o "$file_path" "$url"
        else
            echo "Skipping $file_path (already downloaded)"
        fi
    else
        echo "Downloading $file_path"
        curl -o "$file_path" "$url"
    fi
}

# Loop through the forecast hours and initiate parallel downloads
for (( hour=0; hour<=forecast_hours; hour+=forecast_interval )); do
    current_hour=$(printf "%03d" "$hour")
    file_name="gfs.t${start_time}z.pgrb2.0p25.f$current_hour"
    url="https://ftp.ncep.noaa.gov/data/nccf/com/gfs/prod/gfs.${start_date}/${start_time}/atmos/${file_name}"
    output_path="$output_dir/$file_name"

    # Check if the file already exists or needs to be resumed
    compare_file_size "$output_path" "$url" &
    
    # Limit the number of parallel downloads
    if (( $(jobs -r -p | wc -l) >= num_parallel_downloads )); then
        wait -n
    fi
done

# Wait for all downloads to complete
wait
